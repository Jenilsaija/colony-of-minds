# pyenv
#   For a library or package, you might want to ignore these files since the env is personal
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose to not check in Pipfile.lock, uncomment the following line:
#Pipfile.lock

# poetry
#   Using Poetry, it's recommended to include poetry.lock in version control.
#   However, in case of collaboration, if you choose to not check in poetry.lock, uncomment the following line:
#poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/
__pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
